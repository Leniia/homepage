{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "jekyll: serve",
      "type": "shell",
      "command": "bundle exec jekyll serve --host 127.0.0.1 --port 4000",
      "options": {
        "cwd": "${workspaceFolder}",
        "env": {
          "PATH": "C:\\Ruby31-x64\\bin;${env:PATH}",
          "SSL_CERT_FILE": "C:\\Ruby31-x64\\ssl\\cert.pem"
        }
      },
      "isBackground": true,
      "problemMatcher": {
        "owner": "jekyll",
        "pattern": {
          "regexp": "^$"
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".",
          "endsPattern": "Server (running|address):"
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "focus": false
      }
    }
  ]
}
